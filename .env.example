# Production Supabase Configuration
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Stripe Configuration (Frontend)
# Get this from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Configuration (Backend - Vercel Environment Variables Only)
# NOTE: These should ONLY be set in Vercel project settings, NOT in this file
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ==========================================
# LOCAL DEVELOPMENT (.env.local)
# ==========================================
# For local development with Supabase running in Docker, create a .env.local file:
#
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<get-from-npx-supabase-status>
#
# See README.md → Local Development with Supabase for full setup instructions

# ==========================================
# DATA SYNC (npm run db:pull / db:push-data)
# ==========================================
# Used only by the data-sync scripts to reach the prod database/storage.
# Prod project ref is read from supabase/.temp/project-ref unless set here.
# SUPABASE_PROD_PROJECT_REF=your-prod-project-ref
# SUPABASE_DB_PASSWORD=your-prod-database-password
# SUPABASE_PROD_SERVICE_KEY=your-prod-service-role-key   # for storage sync
# SUPABASE_PROD_POOLER_HOST=aws-1-eu-north-1.pooler.supabase.com
